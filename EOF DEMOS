Samba DC (Контроллер домена)

BR-SRV


apt install samba smbclient winbind krb5-config -y

# Преднастройка kerberos
cat <<EOF > /etc/krb5.conf
[libdefaults]
	default_realm = AU-TEAM.IRPO
	dns_lookup_realm = false
	dns_lookup_kdc = true
EOF

systemctl stop samba-ad-dc smbd nmbd winbind 2>/dev/null
systemctl disable samba-ad-dc smbd nmbd winbind 2>/dev/null
mv /etc/samba/smb.conf /etc/samba/smb.conf.bak

# Создание домена (интерактивный режим заменён флагами)
samba-tool domain provision --use-rfc2307 \
    --realm=AU-TEAM.IRPO \
    --domain=AU-TEAM \
    --server-role=dc \
    --dns-backend=SAMBA_INTERNAL \
    --adminpass='P@ssw0rd' \
    --dns-forwarder=192.168.111.2

cp /var/lib/samba/private/krb5.conf /etc/krb5.conf
systemctl unmask samba-ad-dc
systemctl enable samba-ad-dc
systemctl start samba-ad-dc

# Настройка пользователей и групп
samba-tool group add hq
for i in 1 2 3 4 5; do
    samba-tool user create hquser$i P@ssw0rd
    samba-tool group addmembers hq hquser$i
done

# Restricted Shell для группы hq (настраивается далее)
mkdir -p /usr/local/bin/restricted
ln -sf /usr/bin/cat /usr/local/bin/restricted/cat
ln -sf /usr/bin/grep /usr/local/bin/restricted/grep
ln -sf /usr/bin/id /usr/local/bin/restricted/id

cat <<EOF > /usr/local/bin/restricted_shell.sh
#!/bin/bash
export PATH="/usr/local/bin/restricted"
exec /bin/rbash
EOF
chmod +x /usr/local/bin/restricted_shell.sh

echo "Готово. Добавьте restricted_shell.sh как оболочку для пользователей группы hq в ADUC или через samba-tool."


